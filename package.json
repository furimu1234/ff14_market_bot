{
  "name": "ff14_market_bot",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "install": "pnpm -v",
    "build": "pnpm -F \"@ff14_market/*\" run build",
    "type-check": "pnpm -r --filter \"./packages/*\" run type-check",
    "start": "pnpm -F \"@ff14_market/bot\" start",
    "dev": "pnpm -F \"@ff14_market/bot\" dev",
    "clean": "git clean -Xfd -e pnpm-lock.yaml",
    "generate": "pnpm --filter db run generate",
    "drizzle": "pnpm --filter db drizzle"
  },
  "dependencies": {
    "@sapphire/pieces": "^4.4.1",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0"
  }
}
